# Copy to .env and fill in your keys

# Lava API — get from lava.so dashboard → Build → Secret Keys → Self Forward Token
LAVA_TOKEN=

# ElevenLabs — get from elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Optional: override default LLM (default is gpt-4o-mini via OpenAI)
# LAVA_PROVIDER_URL=https://api.openai.com/v1/chat/completions
# LAVA_MODEL=gpt-4o-mini
